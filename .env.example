# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored so your secret key is never committed.

# Retell secret API key  (Retell Dashboard -> API Keys)
RETELL_API_KEY="key_xxxxxxxxxxxxxxxxxxxx"

# The Retell agent visitors will talk to  (Retell Dashboard -> your Agent -> ID)
RETELL_AGENT_ID="agent_xxxxxxxxxxxxxxxxxxxx"
